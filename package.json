{
  "name": "lumios-leap",
  "version": "0.1.0",
  "description": "Lumio's Leap — an original 2D side-scrolling platformer built with Phaser 3, Vite and TypeScript.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "server": "node server.js"
  },
  "keywords": [
    "phaser",
    "platformer",
    "game",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
